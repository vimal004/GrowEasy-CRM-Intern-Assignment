# ─── Server Configuration ──────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── AI Provider Keys (configure at least ONE) ────────────
# OpenAI (gpt-4o-mini) — Best accuracy, paid
OPENAI_API_KEY=

# Google Gemini (gemini-1.5-flash) — Fast, free tier available
GEMINI_API_KEY=

# Groq (llama-3.1-8b-instant) — Ultra-fast, generous free tier (recommended for testing)
GROQ_API_KEY=

# ─── LLM Provider Selection (optional) ────────────────────
# Auto-detected from keys above if not set.
# Options: openai | gemini | groq | mock
# LLM_PROVIDER=groq

# ─── Processing Configuration ─────────────────────────────
# BATCH_SIZE=25        # Records per AI batch (default: 25)
# MAX_FILE_SIZE=5242880  # Max upload size in bytes (default: 5MB)
